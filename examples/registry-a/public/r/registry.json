{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "registry-a",
  "homepage": "https://github.com/ng-hai/bare-ui",
  "items": [
    {
      "name": "theme",
      "type": "registry:file",
      "title": "Theme A",
      "description": "Blue rounded theme tokens",
      "files": [
        { "path": "registry/a/theme.css", "type": "registry:file", "target": "styles/registry-a-theme.css" }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Blue rounded button styles for bare-ui",
      "registryDependencies": ["ng-hai/bare-ui/button", "@registry-a/theme"],
      "files": [
        { "path": "registry/a/ui/button/styles.ts", "type": "registry:ui" }
      ]
    },
    {
      "name": "input",
      "type": "registry:ui",
      "title": "Input",
      "description": "Blue rounded input styles for bare-ui",
      "registryDependencies": ["ng-hai/bare-ui/input", "@registry-a/theme"],
      "files": [
        { "path": "registry/a/ui/input/styles.ts", "type": "registry:ui" }
      ]
    },
    {
      "name": "checkbox",
      "type": "registry:ui",
      "title": "Checkbox",
      "description": "Blue rounded checkbox styles for bare-ui",
      "registryDependencies": ["ng-hai/bare-ui/checkbox", "@registry-a/theme"],
      "files": [
        { "path": "registry/a/ui/checkbox/styles.ts", "type": "registry:ui" }
      ]
    },
    {
      "name": "switch",
      "type": "registry:ui",
      "title": "Switch",
      "description": "Blue rounded switch styles for bare-ui",
      "registryDependencies": ["ng-hai/bare-ui/switch", "@registry-a/theme"],
      "files": [
        { "path": "registry/a/ui/switch/styles.ts", "type": "registry:ui" }
      ]
    },
    {
      "name": "separator",
      "type": "registry:ui",
      "title": "Separator",
      "description": "Blue separator styles for bare-ui",
      "registryDependencies": ["ng-hai/bare-ui/separator", "@registry-a/theme"],
      "files": [
        { "path": "registry/a/ui/separator/styles.ts", "type": "registry:ui" }
      ]
    }
  ]
}
