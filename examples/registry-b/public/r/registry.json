{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "registry-b",
  "homepage": "https://github.com/ng-hai/bare-ui",
  "items": [
    {
      "name": "theme",
      "type": "registry:file",
      "title": "Theme B",
      "description": "Green sharp theme tokens",
