        { "path": "registry/b/ui/switch/styles.ts", "type": "registry:ui" }
      ]
    },
    {
      "name": "separator",
      "type": "registry:ui",
      "title": "Separator",
      "description": "Green angular separator styles for bare-ui",
      "registryDependencies": ["ng-hai/bare-ui/separator", "@registry-b/theme"],
      "files": [
        { "path": "registry/b/ui/separator/styles.ts", "type": "registry:ui" }
      ]
