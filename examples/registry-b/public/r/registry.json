      "registryDependencies": ["ng-hai/bare-ui/checkbox", "@registry-b/theme"],
      "files": [
        { "path": "registry/b/ui/checkbox/styles.ts", "type": "registry:ui" }
      ]
    },
    {
      "name": "switch",
      "type": "registry:ui",
      "title": "Switch",
